## 6. Conclusion

BFS is useful for finding the shortest path in an unweighted graph.  
DFS is useful for exploring all paths in a graph.



## 7. C++ Code

```cpp
#include <iostream>
#include <vector> 
 #include <queue>
 using namespace std;

 class Graph {
private:
    int V;
    vector<vector<int>> adj;

public:
    Graph(int v) {
          V = v;
         adj.resize(V);
    }

    void addEdge(int u, int v) {
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    void BFS(int start) {
        vector<bool> visited(V, false);
        queue<int> q;

        visited[start] = true;
        q.push(start);

         cout << "BFS: ";

        while (!q.empty()) {
            int node = q.front();
            q.pop();

            cout << char(node + 'A') << " ";

             for (int n : adj[node]) {
                if (!visited[n]) {
                    visited[n] = true;
                    q.push(n);
                }
            }
        }
        cout << endl;
    }

    void DFSHelper(int node, vector<bool>& visited) {
        visited[node] = true;
        cout << char(node + 'A') << " ";

        for (int n : adj[node]) {
            if (!visited[n]) {
                DFSHelper(n, visited);
            }
        }
    }

    void DFS(int start) {
        vector<bool> visited(V, false);
        cout << "DFS: ";
        DFSHelper(start, visited);
        cout << endl;
    }
};

int main() {
    Graph g(7);

     g.addEdge(0, 1); // A-B
    g.addEdge(0, 2); // A-C
     g.addEdge(1, 3); // B-D
    g.addEdge(1, 4); // B-E
    g.addEdge(2, 5);  // C-F
     g.addEdge(2, 6); // C-G 

    g.BFS(0);
    g.DFS(0);

    return 0;
}
