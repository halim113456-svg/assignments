1. Creating an Array of 100 Elements 
an array in C++ is a collection elements of same data typ stored in contiguos memory locations.

#includ <iostream>
using namespace std;

int main () {
  int arr[100]; 


for (int i = 0; i < 100; i++) {
arr[i] = i + 1;

}

cout << "array of 100 elements created successfully." << endl;
return 0;
}



