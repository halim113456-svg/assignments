10. You only need to check if the stack is empty in pop() before removing the top node:

void Stack::pop()
{
    if (isEmpty())  // Check for underflow
    {
        cout << "Stack Underflow" << endl;
        return;
    }

    Node* temp = top;
    top = top->next;
    delete temp;
}
